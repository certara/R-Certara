{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://certara.github.io/R-RsNLME/mcp/kb-manifest.schema.json",
  "title": "Certara MCP KB manifest",
  "description": "Per-package manifest at inst/mcp/kb/manifest.json. Generated; describes the shipped KB slice and its provenance hashes.",
  "schema_version": "1.0.0",
  "type": "object",
  "required": ["package", "schema_version"],
  "additionalProperties": true,
  "properties": {
    "package": { "type": "string" },
    "package_version": { "type": "string" },
    "schema_version": { "type": "string" },
    "generated": { "type": "string", "description": "ISO-8601 generation timestamp." },
    "generator_version": { "type": "string" },
    "entry_count": { "type": "integer" },
    "kinds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Entry types present in this slice."
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" },
          "entry_count": { "type": "integer" }
        }
      }
    },
    "indexes": {
      "type": "object",
      "properties": {
        "symbols": { "type": "string" },
        "enums": { "type": "string" }
      }
    },
    "hashes": {
      "type": "object",
      "description": "Drift detection. Distinguishes source drift, generator drift, and engine drift.",
      "properties": {
        "sources_sha256": { "type": "string" },
        "generator_sha256": { "type": "string" },
        "jsonl_sha256": { "type": "string" },
        "symbols_sha256": { "type": "string" },
        "enums_sha256": { "type": "string" }
      }
    },
    "engine": {
      "type": "object",
      "description": "RsNLME/PML only: the engine version the KB was audited against.",
      "properties": {
        "tdl5_version": { "type": "string" },
        "grammar_source": { "type": "string" },
        "audit_date": { "type": "string" }
      }
    }
  }
}
